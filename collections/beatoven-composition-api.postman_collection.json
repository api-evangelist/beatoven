      "item": [
        {
          "id": "cfc3563f-3064-4a6c-8a04-ffcc6b8b4326",
          "name": "Compose A Track From A Prompt",
          "request": {
            "name": "Compose A Track From A Prompt",
            "description": {
              "content": "Start an asynchronous track composition from a text prompt. Returns a task_id that can be polled at /api/v1/tasks/{task_id} until the track is composed.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "api",
                "v1",
                "tracks",
                "compose"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": []
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prompt\": {\n    \"text\": \"<string>\"\n  },\n  \"format\": \"wav\",\n  \"looping\": false\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
